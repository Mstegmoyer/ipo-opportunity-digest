# Email transport
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=weekly-digest@example.com
SMTP_PASSWORD=change-me
EMAIL_FROM=weekly-digest@example.com
EMAIL_TO=advisory-leadership@example.com

# Runtime
ENVIRONMENT=development
DIGEST_TIMEZONE=America/New_York
LOG_LEVEL=INFO

# Optional model support for summarization/classification of finalists.
# Ranking and selection must remain deterministic in code.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
